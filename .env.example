UPSTAGE_API_KEY=your_upstage_api_key
TOUR_API_KEY=your_tour_api_key
KAKAO_MOBILITY_API_KEY=your_kakao_mobility_api_key
GOOGLE_PLACES_API_KEY=your_google_places_api_key

SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
# LangGraph 체크포인트 저장용 Postgres 직접 연결 문자열(REST API용 SUPABASE_URL과는 다름).
# Supabase 대시보드 > Project Settings > Database > Connection string(URI, Session/Transaction
# pooler 아무거나)에서 복사. 비워두면 체크포인트 없이(기존과 동일하게) 그냥 실행됨.
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com
